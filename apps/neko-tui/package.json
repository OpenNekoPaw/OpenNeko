{
  "name": "@neko/app-tui",
  "version": "0.0.1",
  "description": "Canonical terminal application composition root for OpenNeko",
  "private": true,
  "type": "module",
  "bin": {
    "neko": "./dist/main.js",
    "nekoagent": "./dist/main.js"
  },
  "scripts": {
    "build": "tsup",
    "build:bundle": "tsup",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:sqlite:bun": "bun test src/tui/host/__tests__/bun-sqlite-local-metadata-store.bun.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neko-agent/types": "workspace:*",
    "@neko-canvas/domain": "workspace:*",
    "@neko/agent": "workspace:*",
    "@neko/ai-sdk": "workspace:*",
    "@neko/asset": "workspace:*",
    "@neko/content": "workspace:*",
    "@neko/entity": "workspace:*",
    "@neko/host": "workspace:*",
    "@neko/markdown": "workspace:*",
    "@neko/platform": "workspace:*",
    "@neko/search": "workspace:*",
    "@neko/shared": "workspace:*",
    "adm-zip": "^0.5.16",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "epub2": "^3.0.2",
    "ink": "^5.0.1",
    "lowlight": "^3.3.0",
    "neko-assets": "workspace:*",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "unicode-segmenter": "^0.17.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@neko-agent/test-utils": "workspace:*",
    "@types/bun": "^1.3.10",
    "@types/react": "^18.3.0",
    "esbuild": "^0.20.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.10"
  },
  "license": "AGPL-3.0-or-later"
}
