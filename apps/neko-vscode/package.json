{
  "name": "neko-suite",
  "displayName": "OpenNeko",
  "description": "Local creative suite for media editing, previews, assets, canvas workflows, and AI assistance",
  "version": "0.0.1",
  "publisher": "neko",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/neko/creative-suite"
  },
  "engines": {
    "vscode": "^1.128.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "video",
    "editor",
    "canvas",
    "ai",
    "creative",
    "filmmaking",
    "local-first"
  ],
  "scripts": {
    "vscode:prepublish": "pnpm run compile && node scripts/validate-manifest.mjs",
    "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "test": "node scripts/run-tests.mjs",
    "package": "node ../../scripts/package-openneko-platform.mjs"
  },
  "dependencies": {
    "@neko/shared": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.19.8"
  }
}
