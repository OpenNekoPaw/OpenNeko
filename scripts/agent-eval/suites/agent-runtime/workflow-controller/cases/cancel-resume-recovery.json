{
  "schema": "neko.agent-eval.scenario.v2",
  "id": "cancel-resume-recovery",
  "suiteId": "agent-runtime.workflow-controller",
  "caseGroup": "failure",
  "visibility": "public",
  "evidenceContract": {
    "userBehavior": "Cancel an active turn, resume its canonical conversation, and complete a recovery request.",
    "canonicalPath": ["message.submit", "message.cancel", "session.waitForIdle", "session.resume", "message.submit"],
    "forbiddenFallback": ["new unrelated conversation", "direct history injection", "uncancelled background work"],
    "observables": [{ "ref": "recovery-facts", "kind": "runtime-fact", "description": "Cancellation acceptance, resume identity, recovery submission, and terminal idle facts.", "required": true }],
    "expectedResult": "Cancellation is accepted, the same conversation resumes, and the recovery turn reaches terminal idle.",
    "expectedFailure": "Rejected cancellation, changed conversation identity, missing recovery turn, or busy terminal state fails."
  },
  "fixtureRefs": ["empty-workspace"],
  "runtimeProfileId": "canonical-default",
  "modelProfileIds": ["configured-default"],
  "steps": [
    { "id": "long-turn", "kind": "submit", "prompt": "Begin writing a 300-row five-column Markdown production table. Do not summarize." },
    { "id": "cancel", "kind": "cancel", "afterStepId": "long-turn" },
    { "id": "cancelled-idle", "kind": "wait-for-idle", "timeoutMs": 120000 },
    { "id": "resume", "kind": "resume", "conversationRef": "current" },
    { "id": "recover", "kind": "submit", "prompt": "Recovery request: respond with one concise sentence confirming the prior turn was cancelled." },
    { "id": "recovered-idle", "kind": "wait-for-idle", "timeoutMs": 120000 }
  ],
  "assertions": [
    { "id": "cancelled", "kind": "cancellation", "stepId": "cancel", "accepted": true, "evidenceRef": "recovery-facts" },
    { "id": "recovered", "kind": "recovery", "resumeStepId": "resume", "submitStepId": "recover", "idleStepId": "recovered-idle", "evidenceRef": "recovery-facts" },
    { "id": "terminal", "kind": "terminal-idle", "concerns": ["turnIdle", "backgroundTasksIdle", "taskResultObservationIdle", "continuationQueueIdle"], "evidenceRef": "recovery-facts" },
    { "id": "answer", "kind": "final-answer", "mode": "non-empty", "evidenceRef": "recovery-facts" }
  ],
  "artifactChecks": [],
  "budget": { "timeoutMs": 240000, "repetitions": 1 }
}
