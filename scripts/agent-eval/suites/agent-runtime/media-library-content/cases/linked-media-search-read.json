{
  "schema": "neko.agent-eval.scenario.v2",
  "id": "linked-media-search-read",
  "suiteId": "agent-runtime.media-library-content",
  "caseGroup": "canonical",
  "visibility": "public",
  "evidenceContract": {
    "userBehavior": "Search a linked Media Library by its canonical projection and read the selected workspace-relative file through the normal content capability.",
    "canonicalPath": [
      "TUI input queue",
      "QueryProjectSearch media-library partition",
      "tui-media-library-files adapter",
      "workspace-file locator",
      "ReadImage workspace locator",
      "Host ContentReadService"
    ],
    "forbiddenFallback": [
      "ListAssets",
      "GetAsset",
      "ImportAsset",
      "library.json",
      "project://assets resolver",
      "absolute link target",
      "cache or materialized path"
    ],
    "observables": [
      {
        "ref": "media-library-facts",
        "kind": "runtime-fact",
        "description": "Successful project-search and content-read Tool facts preserve the linked workspace locator and marker text.",
        "required": true
      }
    ],
    "expectedResult": "Search returns neko/assets/Reference/library-image.svg and ReadImage loads that exact workspace-file locator before the final marker.",
    "expectedFailure": "Missing projection, absolute path disclosure, failed image read, Asset Tool participation, runtime diagnostics, or missing marker fails visibly."
  },
  "fixtureRefs": ["media-library-workspace"],
  "runtimeProfileId": "canonical-default",
  "modelProfileIds": ["configured-default"],
  "steps": [
    {
      "id": "submit",
      "kind": "submit",
      "prompt": "严格执行两步：先调用 QueryProjectSearch，query=library-image、mode=agent-tool、partitions=[media-library]、limit=5；再把返回项的 workspace-relative filePath 原样放入 ReadImage 的 images[0].locator={kind:workspace-file,path:<filePath>}，mode=metadata、max_images=1。不要调用 Asset 工具，不要使用绝对路径、链接目标、缓存路径或 project://assets。读取成功后输出 MEDIA_LIBRARY_CANONICAL_7X9，并单独输出 MEDIA_LIBRARY_READ_OK。"
    },
    { "id": "idle", "kind": "wait-for-idle", "timeoutMs": 180000 }
  ],
  "assertions": [
    { "id": "runtime", "kind": "runtime-errors-empty", "evidenceRef": "media-library-facts" },
    { "id": "idle", "kind": "fully-idle", "evidenceRef": "media-library-facts" },
    {
      "id": "search",
      "kind": "tool-call",
      "name": "QueryProjectSearch",
      "status": "success",
      "expectedArguments": {
        "query": "library-image",
        "mode": "agent-tool",
        "partitions": ["media-library"],
        "limit": 5
      },
      "resultIncludes": {
        "itemCount": 1,
        "items": [
          {
            "filePath": "neko/assets/Reference/library-image.svg",
            "source": {
              "partition": "media-library",
              "sourceKind": "workspace-file",
              "projectRelativePath": "neko/assets/Reference/library-image.svg"
            }
          }
        ]
      },
      "evidenceRef": "media-library-facts"
    },
    {
      "id": "read",
      "kind": "tool-call",
      "name": "ReadImage",
      "status": "success",
      "expectedArguments": {
        "images": [
          {
            "locator": {
              "kind": "workspace-file",
              "path": "neko/assets/Reference/library-image.svg"
            }
          }
        ],
        "mode": "metadata",
        "max_images": 1
      },
      "resultIncludes": {
        "mode": "metadata",
        "imageCount": 1,
        "images": [
          {
            "locator": {
              "kind": "workspace-file",
              "path": "neko/assets/Reference/library-image.svg"
            }
          }
        ]
      },
      "evidenceRef": "media-library-facts"
    },
    {
      "id": "order",
      "kind": "process-order",
      "events": [
        { "kind": "tool", "name": "QueryProjectSearch", "status": "success" },
        { "kind": "tool", "name": "ReadImage", "status": "success" }
      ],
      "evidenceRef": "media-library-facts"
    },
    {
      "id": "answer",
      "kind": "final-answer",
      "mode": "contains",
      "text": ["MEDIA_LIBRARY_CANONICAL_7X9", "MEDIA_LIBRARY_READ_OK"],
      "evidenceRef": "media-library-facts"
    },
    {
      "id": "no-asset-fallback",
      "kind": "no-fallback",
      "forbiddenRefs": [
        "ListAssets",
        "GetAsset",
        "ImportAsset",
        "AssetEntity",
        "asset-library",
        "project://assets/",
        "library.json"
      ],
      "evidenceRef": "media-library-facts"
    }
  ],
  "artifactChecks": [
    {
      "id": "legacy-catalog-absent",
      "kind": "file-absent",
      "evidenceRef": "media-library-facts",
      "path": "neko/assets/library.json"
    }
  ],
  "budget": { "timeoutMs": 180000, "repetitions": 1 }
}
