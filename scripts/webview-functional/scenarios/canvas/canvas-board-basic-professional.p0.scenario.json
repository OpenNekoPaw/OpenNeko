{
  "schemaVersion": "neko.webview-functional.scenario.v1",
  "id": "canvas.board-basic-professional.p0",
  "title": "Board Canvas defaults to the foundational Basic catalog and preserves Professional access",
  "ownerPackage": "neko-canvas",
  "tier": "p0",
  "host": "vscode",
  "platforms": ["darwin", "linux"],
  "fixture": {
    "workspace": "scripts/webview-functional/fixtures/canvas-board",
    "digestFiles": ["neko/boards/basic-professional.nkc"]
  },
  "extensions": [
    {
      "id": "neko.neko-canvas",
      "developmentPath": "packages/neko-canvas"
    },
    {
      "id": "neko.neko-engine",
      "developmentPath": "packages/neko-engine"
    },
    {
      "id": "neko.neko-tools",
      "developmentPath": "packages/neko-tools"
    },
    {
      "id": "neko.neko-preview",
      "developmentPath": "packages/neko-preview"
    }
  ],
  "prerequisites": [
    {
      "kind": "package-script",
      "package": "neko-canvas",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-engine",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-tools",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-preview",
      "script": "compile"
    }
  ],
  "activation": {
    "kind": "open-custom-editor",
    "path": "neko/boards/basic-professional.nkc",
    "viewType": "neko.canvasEditor"
  },
  "target": {
    "type": "iframe",
    "extensionId": "neko.neko-canvas",
    "viewType": "neko.canvasEditor"
  },
  "steps": [
    {
      "id": "open-node-library",
      "operation": "click",
      "selector": {
        "css": "[data-canvas-toolbar-action=\"toggle-right-node-tree\"]",
        "auditedSelectorReason": "The Canvas left rail exposes the right-node-tree visibility action through its stable workbench action identity."
      }
    },
    {
      "id": "wait-basic-catalog",
      "operation": "wait-visible",
      "selector": {
        "css": "[data-right-dock-group=\"basic\"] [role=\"tree\"]",
        "auditedSelectorReason": "The shared right-dock group projection and tree role expose the active Basic catalog without coupling to translated labels."
      },
      "timeoutMs": 60000
    },
    {
      "id": "wait-basic-document-entry",
      "operation": "wait-visible",
      "selector": {
        "css": "[data-right-dock-group=\"basic\"] [data-tree-item-id=\"document\"]",
        "auditedSelectorReason": "Basic mode reuses the owning Document descriptor through its stable node type identity."
      }
    },
    {
      "id": "confirm-storyboard-entry-hidden-in-basic",
      "operation": "wait-state",
      "selector": {
        "css": "[data-right-dock-group=\"basic\"] [data-tree-item-id=\"storyboard\"]",
        "auditedSelectorReason": "Basic mode must not expose the specialized Storyboard descriptor as a creation entry."
      },
      "state": {
        "kind": "hidden"
      }
    },
    {
      "id": "wait-existing-professional-node",
      "operation": "wait-visible",
      "selector": {
        "css": "[data-node-id=\"shot-professional-1\"]",
        "auditedSelectorReason": "Canvas nodes expose data-node-id as their stable document identity."
      }
    },
    {
      "id": "switch-professional",
      "operation": "click",
      "selector": {
        "css": ".neko-creative-workbench-right-panel-groups .neko-segmented-control-item[aria-selected=\"false\"]",
        "auditedSelectorReason": "The shared segmented control exposes the inactive Professional tab through its stable class and aria-selected state."
      }
    },
    {
      "id": "wait-professional-catalog",
      "operation": "wait-visible",
      "selector": {
        "css": "[data-right-dock-group=\"professional\"] [data-tree-item-id=\"storyboard\"]",
        "auditedSelectorReason": "Professional mode restores the owning Storyboard descriptor through the stable node type identity."
      }
    }
  ],
  "assertions": [
    {
      "id": "professional-mode-selected",
      "kind": "visible",
      "selector": {
        "css": "[data-right-dock-group=\"professional\"] [data-tree-item-id=\"storyboard\"]",
        "auditedSelectorReason": "Professional mode restores the owning Storyboard descriptor through the stable node type identity."
      }
    },
    {
      "id": "professional-node-remains-in-document",
      "kind": "file-json",
      "path": "neko/boards/basic-professional.nkc",
      "jsonPath": "nodes.1.type",
      "expected": "shot"
    },
    {
      "id": "custom-editor-open-observed",
      "kind": "observation",
      "event": "host.open-custom-editor",
      "source": "vscode-functional-controller"
    },
    {
      "id": "no-runtime-errors",
      "kind": "runtime-errors",
      "expected": []
    }
  ],
  "errorPolicy": {
    "knownBenignWarningIds": [
      "vscode-webview-local-network-access",
      "vscode-webview-sandbox-same-origin-scripts",
      "vscode-development-extension-marketplace-404"
    ],
    "expectedDiagnosticCodes": [],
    "failOnConsoleWarning": true
  },
  "evidence": {
    "domSnapshot": true,
    "screenshot": true,
    "logs": true,
    "sideEffects": true
  },
  "timeoutMs": 60000,
  "tags": ["canvas", "board", "basic", "professional", "catalog"]
}
