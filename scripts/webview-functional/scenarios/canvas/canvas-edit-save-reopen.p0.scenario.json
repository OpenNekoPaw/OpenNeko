{
  "schemaVersion": "neko.webview-functional.scenario.v1",
  "id": "canvas.edit-save-reopen.p0",
  "title": "Canvas Custom Editor edits and persists through the real Webview",
  "ownerPackage": "neko-canvas",
  "tier": "p0",
  "host": "vscode",
  "platforms": ["darwin", "linux"],
  "fixture": {
    "workspace": "scripts/webview-functional/fixtures/canvas",
    "digestFiles": ["project.nkc"]
  },
  "extensions": [
    {
      "id": "neko.neko-canvas",
      "developmentPath": "packages/neko-canvas"
    },
    {
      "id": "neko.neko-engine",
      "developmentPath": "packages/neko-engine"
    },
    {
      "id": "neko.neko-tools",
      "developmentPath": "packages/neko-tools"
    },
    {
      "id": "neko.neko-preview",
      "developmentPath": "packages/neko-preview"
    }
  ],
  "prerequisites": [
    {
      "kind": "package-script",
      "package": "neko-canvas",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-engine",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-tools",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-preview",
      "script": "compile"
    }
  ],
  "activation": {
    "kind": "open-custom-editor",
    "path": "project.nkc",
    "viewType": "neko.canvasEditor"
  },
  "target": {
    "type": "iframe",
    "extensionId": "neko.neko-canvas",
    "viewType": "neko.canvasEditor"
  },
  "steps": [
    {
      "id": "wait-canvas-node",
      "operation": "wait-visible",
      "selector": {
        "css": "[data-node-id=\"text-1\"]",
        "auditedSelectorReason": "Canvas nodes expose data-node-id as their stable document identity and have no generic accessible role."
      },
      "timeoutMs": 60000
    },
    {
      "id": "edit-canvas-text",
      "operation": "input",
      "selector": {
        "css": "[data-node-id=\"text-1\"] textarea",
        "auditedSelectorReason": "The fixture text node exposes its real editable textarea through the built-in Canvas text renderer."
      },
      "value": "Editable Delete must not remove this node"
    },
    {
      "id": "delete-inside-editable",
      "operation": "key",
      "key": "Delete"
    },
    {
      "id": "wait-node-after-editable-delete",
      "operation": "wait-state",
      "selector": {
        "css": "[data-node-id=\"text-1\"]",
        "auditedSelectorReason": "Canvas nodes expose data-node-id as their stable document identity and have no generic accessible role."
      },
      "state": {
        "kind": "visible"
      }
    },
    {
      "id": "select-canvas-node",
      "operation": "click",
      "selector": {
        "css": "[data-node-id=\"text-1\"] .node-header",
        "auditedSelectorReason": "The Canvas node header is the stable non-editable selection surface; clicking the node center would target its textarea and correctly suppress editor shortcuts."
      }
    },
    {
      "id": "wait-canvas-node-selected",
      "operation": "wait-state",
      "selector": {
        "css": "[data-node-id=\"text-1\"] .node-card.selected",
        "auditedSelectorReason": "Canvas exposes selection through the stable node-card selected state used by the visible selection outline."
      },
      "state": {
        "kind": "visible"
      }
    },
    {
      "id": "delete-selected-node",
      "operation": "key",
      "key": "Delete"
    },
    {
      "id": "wait-canvas-node-deleted",
      "operation": "wait-state",
      "selector": {
        "css": "[data-node-id=\"text-1\"]",
        "auditedSelectorReason": "Canvas nodes expose data-node-id as their stable document identity and have no generic accessible role."
      },
      "state": {
        "kind": "hidden"
      },
      "timeoutMs": 5000
    },
    {
      "id": "save-canvas",
      "operation": "save"
    },
    {
      "id": "close-reopen-canvas",
      "operation": "close-reopen",
      "path": "project.nkc",
      "viewType": "neko.canvasEditor"
    },
    {
      "id": "wait-canvas-after-reopen",
      "operation": "wait-visible",
      "selector": {
        "css": ".canvas-workbench-root",
        "auditedSelectorReason": "Canvas workbench root is the existing stable package surface marker."
      }
    }
  ],
  "assertions": [
    {
      "id": "canvas-remains-visible",
      "kind": "visible",
      "selector": {
        "css": ".canvas-workbench-root",
        "auditedSelectorReason": "Canvas workbench root is the existing stable package surface marker."
      }
    },
    {
      "id": "node-delete-is-durable",
      "kind": "file-json",
      "path": "project.nkc",
      "jsonPath": "nodes",
      "expected": []
    },
    {
      "id": "custom-editor-open-observed",
      "kind": "observation",
      "event": "host.open-custom-editor",
      "source": "vscode-functional-controller"
    },
    {
      "id": "no-runtime-errors",
      "kind": "runtime-errors",
      "expected": []
    }
  ],
  "errorPolicy": {
    "knownBenignWarningIds": [
      "vscode-webview-local-network-access",
      "vscode-webview-sandbox-same-origin-scripts",
      "vscode-development-extension-marketplace-404"
    ],
    "expectedDiagnosticCodes": [],
    "failOnConsoleWarning": true
  },
  "evidence": {
    "domSnapshot": true,
    "screenshot": true,
    "logs": true,
    "sideEffects": true
  },
  "timeoutMs": 60000,
  "tags": ["canvas", "custom-editor", "keyboard", "save", "reopen"]
}
