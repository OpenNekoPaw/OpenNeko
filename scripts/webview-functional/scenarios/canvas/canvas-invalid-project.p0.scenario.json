{
  "schemaVersion": "neko.webview-functional.scenario.v1",
  "id": "canvas.invalid-project.p0",
  "title": "Canvas Custom Editor rejects invalid JSON without fallback success",
  "ownerPackage": "neko-canvas",
  "tier": "p0",
  "host": "vscode",
  "platforms": ["darwin", "linux"],
  "fixture": {
    "workspace": "scripts/webview-functional/fixtures/canvas-invalid",
    "digestFiles": ["project.nkc"]
  },
  "extensions": [
    { "id": "neko.neko-canvas", "developmentPath": "packages/neko-canvas" },
    { "id": "neko.neko-engine", "developmentPath": "packages/neko-engine" },
    { "id": "neko.neko-tools", "developmentPath": "packages/neko-tools" },
    { "id": "neko.neko-preview", "developmentPath": "packages/neko-preview" }
  ],
  "prerequisites": [
    { "kind": "package-script", "package": "neko-canvas", "script": "compile" },
    { "kind": "package-script", "package": "neko-engine", "script": "compile" },
    { "kind": "package-script", "package": "neko-tools", "script": "compile" },
    { "kind": "package-script", "package": "neko-preview", "script": "compile" }
  ],
  "activation": {
    "kind": "open-custom-editor",
    "path": "project.nkc",
    "viewType": "neko.canvasEditor"
  },
  "target": {
    "type": "iframe",
    "extensionId": "neko.neko-canvas",
    "viewType": "neko.canvasEditor"
  },
  "steps": [
    {
      "id": "wait-load-diagnostic",
      "operation": "wait-visible",
      "selector": { "testId": "canvas-load-diagnostic" },
      "timeoutMs": 60000
    }
  ],
  "assertions": [
    {
      "id": "invalid-project-is-visible",
      "kind": "visible",
      "selector": { "testId": "canvas-load-diagnostic" }
    },
    {
      "id": "invalid-project-is-typed",
      "kind": "attribute",
      "selector": { "testId": "canvas-load-diagnostic" },
      "attribute": "data-diagnostic-code",
      "expected": "canvas.project.invalid-json"
    },
    {
      "id": "canvas-workbench-does-not-fallback",
      "kind": "hidden",
      "selector": {
        "css": ".canvas-workbench-root",
        "auditedSelectorReason": "The Canvas workbench root is the stable package surface marker and must not appear for an invalid project."
      }
    },
    {
      "id": "invalid-project-remains-unchanged",
      "kind": "file-text",
      "path": "project.nkc",
      "expected": { "contains": "[ invalid json" }
    },
    {
      "id": "no-runtime-errors",
      "kind": "runtime-errors",
      "expected": []
    }
  ],
  "errorPolicy": {
    "knownBenignWarningIds": [
      "vscode-webview-local-network-access",
      "vscode-webview-sandbox-same-origin-scripts",
      "vscode-development-extension-marketplace-404"
    ],
    "expectedDiagnosticCodes": [],
    "failOnConsoleWarning": true
  },
  "evidence": {
    "domSnapshot": true,
    "screenshot": true,
    "logs": true,
    "sideEffects": true
  },
  "timeoutMs": 60000,
  "tags": ["canvas", "custom-editor", "invalid-input", "diagnostic", "no-fallback"]
}
