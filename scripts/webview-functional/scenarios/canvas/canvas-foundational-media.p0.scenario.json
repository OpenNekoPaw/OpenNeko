{
  "schemaVersion": "neko.webview-functional.scenario.v1",
  "id": "canvas.foundational-media.p0",
  "title": "Canvas foundational Media uses full-bleed content and overflow fullscreen",
  "ownerPackage": "neko-canvas",
  "tier": "p0",
  "host": "vscode",
  "platforms": ["darwin", "linux"],
  "fixture": {
    "workspace": "scripts/webview-functional/fixtures/canvas-board",
    "digestFiles": ["neko/boards/foundational-media.nkc", "assets/foundational-cover.svg"]
  },
  "extensions": [
    {
      "id": "neko.neko-canvas",
      "developmentPath": "packages/neko-canvas"
    },
    {
      "id": "neko.neko-engine",
      "developmentPath": "packages/neko-engine"
    },
    {
      "id": "neko.neko-tools",
      "developmentPath": "packages/neko-tools"
    },
    {
      "id": "neko.neko-preview",
      "developmentPath": "packages/neko-preview"
    }
  ],
  "prerequisites": [
    {
      "kind": "package-script",
      "package": "neko-canvas",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-engine",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-tools",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-preview",
      "script": "compile"
    }
  ],
  "activation": {
    "kind": "open-custom-editor",
    "path": "neko/boards/foundational-media.nkc",
    "viewType": "neko.canvasEditor"
  },
  "target": {
    "type": "iframe",
    "extensionId": "neko.neko-canvas",
    "viewType": "neko.canvasEditor"
  },
  "errorPolicy": {
    "knownBenignWarningIds": [
      "vscode-webview-local-network-access",
      "vscode-webview-sandbox-same-origin-scripts",
      "vscode-development-extension-marketplace-404"
    ],
    "expectedDiagnosticCodes": [],
    "failOnConsoleWarning": true
  },
  "evidence": {
    "domSnapshot": true,
    "screenshot": true,
    "logs": true,
    "sideEffects": true
  },
  "timeoutMs": 60000,
  "tags": ["canvas", "foundational", "media", "resource-ref", "fullscreen"],
  "steps": [
    {
      "id": "wait-foundational-media",
      "operation": "wait-visible",
      "selector": {
        "css": "[data-node-id=\"media-foundational\"]",
        "auditedSelectorReason": "The persisted Media node identity is the public Canvas interaction target."
      },
      "timeoutMs": 60000
    },
    {
      "id": "select-foundational-media",
      "operation": "click",
      "selector": {
        "css": "[data-node-id=\"media-foundational\"]",
        "auditedSelectorReason": "Selecting the persisted Media node exposes the canonical selection toolbar."
      }
    },
    {
      "id": "wait-foundational-media-overflow",
      "operation": "wait-visible",
      "selector": {
        "css": "[data-selection-overflow=\"true\"][data-selection-overflow-actions~=\"node:open-content-overlay\"]",
        "auditedSelectorReason": "The selected-node toolbar exposes fullscreen through its overflow action contract."
      }
    },
    {
      "id": "open-foundational-media-actions",
      "operation": "click",
      "selector": {
        "css": "[data-selection-overflow=\"true\"]",
        "auditedSelectorReason": "The visible overflow trigger is the public entry to secondary selected-node actions."
      }
    },
    {
      "id": "wait-foundational-fullscreen-action",
      "operation": "wait-visible",
      "selector": {
        "css": "[data-selection-action=\"node:open-content-overlay\"][data-selection-action-location=\"overflow\"]",
        "auditedSelectorReason": "Fullscreen is rendered as an overflow action rather than persistent node-header chrome."
      }
    },
    {
      "id": "capture-foundational-media-actions",
      "operation": "screenshot",
      "screenshotName": "canvas-foundational-media-actions"
    },
    {
      "id": "open-foundational-media-fullscreen",
      "operation": "click",
      "selector": {
        "css": "[data-selection-action=\"node:open-content-overlay\"][data-selection-action-location=\"overflow\"]",
        "auditedSelectorReason": "The overflow action dispatches the canonical content-overlay handler."
      }
    },
    {
      "id": "wait-foundational-media-overlay",
      "operation": "wait-visible",
      "selector": {
        "css": "[data-content-overlay-root=\"true\"]",
        "auditedSelectorReason": "The canonical fullscreen content overlay is the authoritative action result."
      }
    }
  ],
  "assertions": [
    {
      "id": "foundational-media-title-uses-resource-filename",
      "kind": "text",
      "selector": {
        "css": "[data-node-id=\"media-foundational\"] .node-header > span",
        "auditedSelectorReason": "The foundational Media title exposes the display name projected from its stable ResourceRef."
      },
      "expected": "foundational-cover.svg"
    },
    {
      "id": "foundational-media-content-is-full-bleed",
      "kind": "attribute",
      "selector": {
        "css": "[data-node-id=\"media-foundational\"] [data-node-content-chrome]",
        "auditedSelectorReason": "NodeShell publishes its descriptor-derived content chrome contract for runtime acceptance."
      },
      "attribute": "data-node-content-chrome",
      "expected": "full-bleed"
    },
    {
      "id": "foundational-media-preview-is-full-bleed",
      "kind": "attribute",
      "selector": {
        "css": "[data-node-id=\"media-foundational\"] [data-preview-surface]",
        "auditedSelectorReason": "The canonical PreviewSurface exposes the renderer-independent full-bleed frame contract."
      },
      "attribute": "data-preview-chrome",
      "expected": "full-bleed"
    },
    {
      "id": "foundational-fullscreen-is-overflow-only",
      "kind": "attribute",
      "selector": {
        "css": "[data-selection-overflow=\"true\"]",
        "auditedSelectorReason": "The toolbar trigger declares the secondary action identities currently owned by overflow."
      },
      "attribute": "data-selection-overflow-actions",
      "expected": "node:open-content-overlay delete-selection"
    },
    {
      "id": "stable-resource-ref-is-persisted",
      "kind": "file-json",
      "path": "neko/boards/foundational-media.nkc",
      "jsonPath": "nodes.0.data.resourceRef.source.projectRelativePath",
      "expected": "assets/foundational-cover.svg"
    },
    {
      "id": "custom-editor-open-observed",
      "kind": "observation",
      "event": "host.open-custom-editor",
      "source": "vscode-functional-controller"
    },
    {
      "id": "no-runtime-errors",
      "kind": "runtime-errors",
      "expected": []
    }
  ]
}
