{
  "schemaVersion": "neko.webview-functional.scenario.v1",
  "id": "story.edit-diagnostic-save-reopen.p0",
  "title": "Story source editing refreshes Preview and preserves typed diagnostics after reopen",
  "ownerPackage": "neko-story",
  "tier": "p0",
  "host": "vscode",
  "platforms": ["darwin", "linux"],
  "fixture": {
    "workspace": "scripts/webview-functional/fixtures/story",
    "digestFiles": ["story.fountain"]
  },
  "extensions": [
    { "id": "neko.neko-story", "developmentPath": "packages/neko-story" },
    { "id": "neko.neko-engine", "developmentPath": "packages/neko-engine" },
    { "id": "neko.neko-tools", "developmentPath": "packages/neko-tools" }
  ],
  "prerequisites": [
    { "kind": "package-script", "package": "neko-story", "script": "compile" },
    { "kind": "package-script", "package": "neko-engine", "script": "compile" },
    { "kind": "package-script", "package": "neko-tools", "script": "compile" }
  ],
  "activation": {
    "kind": "open-file-command",
    "path": "story.fountain",
    "command": "neko.story.preview"
  },
  "target": {
    "type": "iframe",
    "extensionId": "neko.neko-story"
  },
  "steps": [
    {
      "id": "wait-story-preview",
      "operation": "wait-visible",
      "selector": {
        "css": ".story-view-shell",
        "auditedSelectorReason": "story-view-shell is the stable root of the real Story Preview panel."
      }
    },
    {
      "id": "wait-scene-heading",
      "operation": "wait-visible",
      "selector": {
        "css": ".scene-heading",
        "auditedSelectorReason": "The parsed Fountain scene heading is the stable source-navigation surface in Story Preview."
      }
    },
    {
      "id": "navigate-preview-to-source",
      "operation": "click",
      "selector": {
        "css": ".scene-heading",
        "auditedSelectorReason": "Clicking the rendered scene heading exercises the real Webview navigate message and focuses its owning source editor."
      }
    },
    {
      "id": "edit-story-source",
      "operation": "host-command",
      "command": "type",
      "args": [{ "text": "Functional edit persisted.\n[[BROKEN\n" }]
    },
    { "id": "save-story-source", "operation": "save" },
    {
      "id": "wait-preview-refresh",
      "operation": "wait-state",
      "selector": {
        "css": ".action",
        "auditedSelectorReason": "The first parsed action is the visible projection of the source edit after Story Preview refresh."
      },
      "state": { "kind": "text", "value": "Functional edit persisted." },
      "timeoutMs": 10000
    },
    {
      "id": "read-edited-diagnostics",
      "operation": "read-diagnostics",
      "path": "story.fountain"
    },
    {
      "id": "close-story-source",
      "operation": "host-command",
      "command": "workbench.action.closeActiveEditor"
    },
    { "id": "reopen-story-source", "operation": "open-file", "path": "story.fountain" },
    {
      "id": "wait-reopened-preview",
      "operation": "wait-state",
      "selector": {
        "css": ".action",
        "auditedSelectorReason": "The same Story Preview panel must re-project durable source content after the text editor is reopened."
      },
      "state": { "kind": "text", "value": "Functional edit persisted." },
      "timeoutMs": 10000
    },
    {
      "id": "read-reopened-diagnostics",
      "operation": "read-diagnostics",
      "path": "story.fountain"
    }
  ],
  "assertions": [
    {
      "id": "edited-preview-is-visible",
      "kind": "text",
      "selector": {
        "css": ".story-view-shell",
        "auditedSelectorReason": "The Story Preview root contains the complete visible source projection after refresh."
      },
      "expected": { "contains": "Functional edit persisted." }
    },
    {
      "id": "story-source-is-durable",
      "kind": "file-text",
      "path": "story.fountain",
      "expected": { "contains": "Functional edit persisted.\n[[BROKEN" }
    },
    {
      "id": "story-diagnostic-survives-reopen",
      "kind": "diagnostic",
      "code": "story.syntax.unclosed-note",
      "stepId": "read-reopened-diagnostics"
    },
    { "id": "no-runtime-errors", "kind": "runtime-errors", "expected": [] }
  ],
  "errorPolicy": {
    "knownBenignWarningIds": [
      "vscode-webview-local-network-access",
      "vscode-webview-sandbox-same-origin-scripts",
      "vscode-development-extension-marketplace-404"
    ],
    "expectedDiagnosticCodes": [],
    "failOnConsoleWarning": true
  },
  "evidence": { "domSnapshot": true, "screenshot": true, "logs": true, "sideEffects": true },
  "timeoutMs": 60000,
  "tags": ["story", "source", "preview", "diagnostic", "save", "reopen"]
}
