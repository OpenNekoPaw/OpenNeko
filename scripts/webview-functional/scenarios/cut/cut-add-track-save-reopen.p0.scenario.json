{
  "schemaVersion": "neko.webview-functional.scenario.v1",
  "id": "cut.add-track-save-reopen.p0",
  "title": "Cut adds a timeline track and persists it through the real Custom Editor",
  "ownerPackage": "neko-cut",
  "tier": "p0",
  "host": "vscode",
  "platforms": ["darwin", "linux"],
  "fixture": {
    "workspace": "scripts/webview-functional/fixtures/cut",
    "digestFiles": ["project.nkv"]
  },
  "extensions": [
    { "id": "neko.neko-cut", "developmentPath": "packages/neko-cut" },
    { "id": "neko.neko-engine", "developmentPath": "packages/neko-engine" },
    { "id": "neko.neko-tools", "developmentPath": "packages/neko-tools" },
    { "id": "neko.neko-preview", "developmentPath": "packages/neko-preview" }
  ],
  "prerequisites": [
    { "kind": "package-script", "package": "@neko/webview", "script": "build" },
    { "kind": "package-script", "package": "neko-cut", "script": "compile" },
    { "kind": "package-script", "package": "neko-engine", "script": "compile" },
    { "kind": "package-script", "package": "neko-tools", "script": "compile" },
    { "kind": "package-script", "package": "neko-preview", "script": "compile" }
  ],
  "activation": {
    "kind": "open-custom-editor",
    "path": "project.nkv",
    "viewType": "neko.videoEditor"
  },
  "target": {
    "type": "iframe",
    "extensionId": "neko.neko-cut",
    "viewType": "neko.videoEditor"
  },
  "steps": [
    {
      "id": "wait-cut-workbench",
      "operation": "wait-visible",
      "selector": {
        "css": ".cut-workbench-shell",
        "auditedSelectorReason": "cut-workbench-shell is the stable root of the real Cut editor surface."
      },
      "timeoutMs": 60000
    },
    {
      "id": "wait-main-track",
      "operation": "wait-visible",
      "selector": {
        "css": ".track-label:first-child",
        "auditedSelectorReason": "Cut track-label rows are the stable timeline projection of persisted project tracks."
      }
    },
    {
      "id": "add-audio-track",
      "operation": "click",
      "selector": {
        "css": "#cut-main-panel-tools button:nth-child(2)",
        "auditedSelectorReason": "The second documented Cut add-track control is Audio; structural selection avoids locale-dependent title text."
      }
    },
    {
      "id": "wait-audio-track",
      "operation": "wait-state",
      "selector": {
        "css": ".track-label:nth-child(2)",
        "auditedSelectorReason": "The second track-label row is the visible result of adding the Audio track."
      },
      "state": { "kind": "visible" }
    },
    {
      "id": "read-engine-status",
      "operation": "host-command",
      "command": "neko.engine.getStatus"
    },
    { "id": "save-cut-project", "operation": "save" },
    {
      "id": "close-reopen-cut-project",
      "operation": "close-reopen",
      "path": "project.nkv",
      "viewType": "neko.videoEditor"
    },
    {
      "id": "wait-audio-track-after-reopen",
      "operation": "wait-state",
      "selector": {
        "css": ".track-label:nth-child(2)",
        "auditedSelectorReason": "The reopened second track row proves the saved project was projected back into the Cut Webview."
      },
      "state": { "kind": "visible" }
    }
  ],
  "assertions": [
    {
      "id": "audio-track-is-durable",
      "kind": "file-json",
      "path": "project.nkv",
      "jsonPath": "tracks.1.type",
      "expected": "audio"
    },
    {
      "id": "custom-editor-open-observed",
      "kind": "observation",
      "event": "host.open-custom-editor",
      "source": "vscode-functional-controller"
    },
    {
      "id": "real-engine-is-ready",
      "kind": "engine-result",
      "stepId": "read-engine-status",
      "jsonPath": "state",
      "expected": "ready"
    },
    { "id": "no-runtime-errors", "kind": "runtime-errors", "expected": [] }
  ],
  "errorPolicy": {
    "knownBenignWarningIds": [
      "vscode-webview-local-network-access",
      "vscode-webview-sandbox-same-origin-scripts",
      "vscode-development-extension-marketplace-404"
    ],
    "expectedDiagnosticCodes": [],
    "failOnConsoleWarning": true
  },
  "evidence": { "domSnapshot": true, "screenshot": true, "logs": true, "sideEffects": true },
  "timeoutMs": 60000,
  "tags": ["cut", "timeline", "track", "save", "reopen"]
}
