{
  "schemaVersion": "neko.webview-functional.scenario.v1",
  "id": "cut.engine-unavailable-authoring.p0",
  "title": "Cut remains authorable after the real Engine session becomes unavailable",
  "ownerPackage": "neko-cut",
  "tier": "p0",
  "host": "vscode",
  "platforms": ["darwin", "linux"],
  "fixture": {
    "workspace": "scripts/webview-functional/fixtures/cut",
    "digestFiles": ["project.nkv"]
  },
  "extensions": [
    { "id": "neko.neko-cut", "developmentPath": "packages/neko-cut" },
    { "id": "neko.neko-engine", "developmentPath": "packages/neko-engine" },
    { "id": "neko.neko-tools", "developmentPath": "packages/neko-tools" },
    { "id": "neko.neko-preview", "developmentPath": "packages/neko-preview" }
  ],
  "prerequisites": [
    { "kind": "package-script", "package": "@neko/webview", "script": "build" },
    { "kind": "package-script", "package": "neko-cut", "script": "compile" },
    { "kind": "package-script", "package": "neko-engine", "script": "compile" },
    { "kind": "package-script", "package": "neko-tools", "script": "compile" },
    { "kind": "package-script", "package": "neko-preview", "script": "compile" }
  ],
  "activation": {
    "kind": "open-custom-editor",
    "path": "project.nkv",
    "viewType": "neko.videoEditor"
  },
  "target": {
    "type": "iframe",
    "extensionId": "neko.neko-cut",
    "viewType": "neko.videoEditor"
  },
  "steps": [
    {
      "id": "wait-cut-workbench",
      "operation": "wait-visible",
      "selector": {
        "css": ".cut-workbench-shell",
        "auditedSelectorReason": "cut-workbench-shell is the stable root of the real Cut editor surface."
      },
      "timeoutMs": 60000
    },
    {
      "id": "stop-real-engine-session",
      "operation": "host-command",
      "command": "neko.engine.stop"
    },
    {
      "id": "read-stopped-engine-status",
      "operation": "host-command",
      "command": "neko.engine.getStatus"
    },
    {
      "id": "add-text-track-without-engine",
      "operation": "click",
      "selector": {
        "css": "#cut-main-panel-tools button:nth-child(3)",
        "auditedSelectorReason": "The third documented Cut add-track control is Text; structural selection avoids locale-dependent title text."
      }
    },
    {
      "id": "wait-engine-stream-unavailable-diagnostic",
      "operation": "wait-visible",
      "selector": {
        "css": "[role=\"alert\"][data-diagnostic-code=\"cut.engine.stream-unavailable\"]",
        "auditedSelectorReason": "The typed Cut stream diagnostic is the public failure projection after a UI action reaches the stopped Engine stream."
      },
      "timeoutMs": 10000
    },
    {
      "id": "wait-text-track",
      "operation": "wait-state",
      "selector": {
        "css": ".track-label:nth-child(2)",
        "auditedSelectorReason": "The second track row is the visible result of authoring after Engine shutdown."
      },
      "state": { "kind": "visible" }
    },
    { "id": "save-cut-without-engine", "operation": "save" }
  ],
  "assertions": [
    {
      "id": "engine-session-is-unavailable",
      "kind": "engine-result",
      "stepId": "read-stopped-engine-status",
      "jsonPath": "state",
      "expected": "idle"
    },
    {
      "id": "text-track-is-durable-without-engine",
      "kind": "file-json",
      "path": "project.nkv",
      "jsonPath": "tracks.1.type",
      "expected": "text"
    },
    {
      "id": "engine-stream-unavailable-is-typed",
      "kind": "diagnostic",
      "code": "cut.engine.stream-unavailable"
    },
    { "id": "no-runtime-errors", "kind": "runtime-errors", "expected": [] }
  ],
  "errorPolicy": {
    "knownBenignWarningIds": [
      "vscode-webview-local-network-access",
      "vscode-webview-sandbox-same-origin-scripts",
      "vscode-development-extension-marketplace-404"
    ],
    "expectedDiagnosticCodes": ["cut.engine.stream-unavailable"],
    "failOnConsoleWarning": true
  },
  "evidence": { "domSnapshot": true, "screenshot": true, "logs": true, "sideEffects": true },
  "timeoutMs": 60000,
  "tags": ["cut", "engine", "unavailable", "authoring", "save"]
}
