{
  "schemaVersion": "neko.webview-functional.scenario.v1",
  "id": "agent.view-submit.p0",
  "title": "Agent View accepts input through the real Extension Webview",
  "ownerPackage": "neko-agent",
  "tier": "p0",
  "host": "vscode",
  "platforms": ["darwin", "linux"],
  "fixture": {
    "workspace": "scripts/webview-functional/fixtures/agent",
    "digestFiles": ["README.md"]
  },
  "extensions": [
    {
      "id": "neko.neko-agent",
      "developmentPath": "packages/neko-agent"
    },
    {
      "id": "neko.neko-engine",
      "developmentPath": "packages/neko-engine"
    },
    {
      "id": "neko.neko-tools",
      "developmentPath": "packages/neko-tools"
    },
    {
      "id": "neko.neko-preview",
      "developmentPath": "packages/neko-preview"
    }
  ],
  "prerequisites": [
    {
      "kind": "package-script",
      "package": "neko-agent",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-engine",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-tools",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-preview",
      "script": "compile"
    }
  ],
  "activation": {
    "kind": "command",
    "command": "workbench.view.extension.neko-assistant"
  },
  "target": {
    "type": "iframe",
    "extensionId": "neko.neko-agent",
    "viewType": "neko.aiAssistant"
  },
  "steps": [
    {
      "id": "wait-agent-input",
      "operation": "wait-visible",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the actual message input."
      },
      "timeoutMs": 60000
    },
    {
      "id": "enter-agent-message",
      "operation": "input",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the actual message input."
      },
      "value": "Functional host message"
    },
    {
      "id": "wait-agent-message-value",
      "operation": "wait-state",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the actual message input."
      },
      "state": {
        "kind": "value",
        "value": "Functional host message"
      }
    },
    {
      "id": "wait-agent-send-enabled",
      "operation": "wait-state",
      "selector": {
        "css": ".agent-composer-action-button.agent-composer-send",
        "auditedSelectorReason": "The existing composer send-state class is the stable contract distinguishing an enabled send action from queue, stop, and muted actions."
      },
      "state": {
        "kind": "enabled"
      }
    },
    {
      "id": "submit-agent-message",
      "operation": "click",
      "selector": {
        "css": ".agent-composer-action-button.agent-composer-send",
        "auditedSelectorReason": "The existing composer send-state class is the stable contract distinguishing the real send action from queue and stop actions."
      }
    },
    {
      "id": "wait-user-projection",
      "operation": "wait-state",
      "selector": {
        "css": ".agent-bubble-user",
        "name": "Functional host message",
        "auditedSelectorReason": "The message bubble has no role or test id; agent-bubble-user is its existing stable UI class."
      },
      "state": {
        "kind": "text",
        "value": "Functional host message"
      },
      "timeoutMs": 30000
    },
    {
      "id": "hide-reveal-agent-panel",
      "operation": "hide-reveal"
    },
    {
      "id": "wait-agent-input-after-reveal",
      "operation": "wait-visible",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the actual message input after reveal."
      }
    },
    {
      "id": "continue-agent-input-after-reveal",
      "operation": "input",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the actual message input after reveal."
      },
      "value": "Continued after reveal"
    },
    {
      "id": "wait-continued-agent-input-value",
      "operation": "wait-state",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the actual message input after reveal."
      },
      "state": {
        "kind": "value",
        "value": "Continued after reveal"
      }
    }
  ],
  "assertions": [
    {
      "id": "user-message-visible",
      "kind": "text",
      "selector": {
        "css": ".agent-bubble-user",
        "name": "Functional host message",
        "auditedSelectorReason": "The message bubble has no role or test id; agent-bubble-user is its existing stable UI class."
      },
      "expected": {
        "contains": "Functional host message"
      }
    },
    {
      "id": "real-view-command-observed",
      "kind": "observation",
      "event": "host.execute-command",
      "source": "vscode-functional-controller"
    },
    {
      "id": "message-survives-panel-hide-reveal",
      "kind": "lifecycle",
      "event": "host.hide-reveal",
      "source": "vscode-functional-controller"
    },
    {
      "id": "continued-input-usable-after-reveal",
      "kind": "value",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the actual message input after reveal."
      },
      "expected": {
        "equals": "Continued after reveal"
      }
    },
    {
      "id": "no-runtime-errors",
      "kind": "runtime-errors",
      "expected": []
    }
  ],
  "errorPolicy": {
    "knownBenignWarningIds": [
      "vscode-webview-local-network-access",
      "vscode-webview-sandbox-same-origin-scripts",
      "vscode-development-extension-marketplace-404"
    ],
    "expectedDiagnosticCodes": [
      "missing-primary-model",
      "missing-primary-provider",
      "primary-provider-not-configured"
    ],
    "failOnConsoleWarning": true
  },
  "evidence": {
    "domSnapshot": true,
    "screenshot": true,
    "logs": true,
    "sideEffects": true
  },
  "timeoutMs": 60000,
  "tags": ["agent", "view", "input", "lifecycle"]
}
