{
  "schemaVersion": "neko.webview-functional.scenario.v1",
  "id": "agent.lifecycle-reload.p0",
  "title": "Agent View isolates Webview realms across hide and reload",
  "ownerPackage": "neko-agent",
  "tier": "p0",
  "host": "vscode",
  "platforms": ["darwin", "linux"],
  "fixture": {
    "workspace": "scripts/webview-functional/fixtures/agent",
    "digestFiles": ["README.md"]
  },
  "extensions": [
    {
      "id": "neko.neko-agent",
      "developmentPath": "packages/neko-agent"
    },
    {
      "id": "neko.neko-engine",
      "developmentPath": "packages/neko-engine"
    },
    {
      "id": "neko.neko-tools",
      "developmentPath": "packages/neko-tools"
    },
    {
      "id": "neko.neko-preview",
      "developmentPath": "packages/neko-preview"
    }
  ],
  "prerequisites": [
    {
      "kind": "package-script",
      "package": "neko-agent",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-engine",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-tools",
      "script": "compile"
    },
    {
      "kind": "package-script",
      "package": "neko-preview",
      "script": "compile"
    }
  ],
  "activation": {
    "kind": "command",
    "command": "workbench.view.extension.neko-assistant"
  },
  "target": {
    "type": "iframe",
    "extensionId": "neko.neko-agent",
    "viewType": "neko.aiAssistant"
  },
  "steps": [
    {
      "id": "wait-initial-input",
      "operation": "wait-visible",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the actual message input."
      },
      "timeoutMs": 60000
    },
    {
      "id": "enter-lifecycle-message",
      "operation": "input",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the actual message input."
      },
      "value": "Lifecycle host projection"
    },
    {
      "id": "wait-lifecycle-send-enabled",
      "operation": "wait-state",
      "selector": {
        "css": ".agent-composer-action-button.agent-composer-send",
        "auditedSelectorReason": "The existing composer send-state class is the stable contract distinguishing the real send action from queue and stop actions."
      },
      "state": {
        "kind": "enabled"
      }
    },
    {
      "id": "submit-lifecycle-message",
      "operation": "click",
      "selector": {
        "css": ".agent-composer-action-button.agent-composer-send",
        "auditedSelectorReason": "The existing composer send-state class is the stable contract distinguishing the real send action from queue and stop actions."
      }
    },
    {
      "id": "wait-initial-host-projection",
      "operation": "wait-state",
      "selector": {
        "css": ".agent-bubble-user",
        "name": "Lifecycle host projection",
        "auditedSelectorReason": "The message bubble has no role or test id; agent-bubble-user is its existing stable UI class."
      },
      "state": {
        "kind": "text",
        "value": "Lifecycle host projection"
      },
      "timeoutMs": 30000
    },
    {
      "id": "hide-reveal-agent-panel",
      "operation": "hide-reveal"
    },
    {
      "id": "wait-restored-host-projection",
      "operation": "wait-state",
      "selector": {
        "css": ".agent-bubble-user",
        "name": "Lifecycle host projection",
        "auditedSelectorReason": "The message bubble has no role or test id; agent-bubble-user is its existing stable UI class."
      },
      "state": {
        "kind": "text",
        "value": "Lifecycle host projection"
      },
      "timeoutMs": 30000
    },
    {
      "id": "reload-extension-host-window",
      "operation": "reload"
    },
    {
      "id": "wait-fresh-realm-input",
      "operation": "wait-visible",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the fresh realm message input."
      },
      "timeoutMs": 60000
    },
    {
      "id": "wait-stale-message-absent",
      "operation": "wait-state",
      "selector": {
        "css": ".agent-bubble-user",
        "name": "Lifecycle host projection",
        "auditedSelectorReason": "The message bubble has no role or test id; absence after reload proves the fresh entry realm did not retain stale active projection DOM."
      },
      "state": {
        "kind": "hidden"
      }
    },
    {
      "id": "enter-fresh-realm-input",
      "operation": "input",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the fresh realm message input."
      },
      "value": "Fresh realm after reload"
    },
    {
      "id": "wait-fresh-realm-input-value",
      "operation": "wait-state",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the fresh realm message input."
      },
      "state": {
        "kind": "value",
        "value": "Fresh realm after reload"
      }
    }
  ],
  "assertions": [
    {
      "id": "stale-message-not-projected-after-reload",
      "kind": "hidden",
      "selector": {
        "css": ".agent-bubble-user",
        "name": "Lifecycle host projection",
        "auditedSelectorReason": "The message bubble has no role or test id; absence after reload proves the fresh entry realm did not retain stale active projection DOM."
      }
    },
    {
      "id": "fresh-realm-remains-interactive",
      "kind": "value",
      "selector": {
        "css": ".agent-composer-textarea",
        "auditedSelectorReason": "The Agent history menu also contains a search textbox; the composer class identifies the fresh realm message input."
      },
      "expected": {
        "equals": "Fresh realm after reload"
      }
    },
    {
      "id": "hide-reveal-command-observed",
      "kind": "lifecycle",
      "event": "host.hide-reveal",
      "source": "vscode-functional-controller"
    },
    {
      "id": "reload-command-observed",
      "kind": "lifecycle",
      "event": "host.reload-window",
      "source": "vscode-functional-host"
    },
    {
      "id": "no-runtime-errors",
      "kind": "runtime-errors",
      "expected": []
    }
  ],
  "errorPolicy": {
    "knownBenignWarningIds": [
      "vscode-webview-local-network-access",
      "vscode-webview-sandbox-same-origin-scripts",
      "vscode-development-extension-marketplace-404"
    ],
    "expectedDiagnosticCodes": [
      "missing-primary-model",
      "missing-primary-provider",
      "primary-provider-not-configured"
    ],
    "failOnConsoleWarning": true
  },
  "evidence": {
    "domSnapshot": true,
    "screenshot": true,
    "logs": true,
    "sideEffects": true
  },
  "timeoutMs": 60000,
  "tags": ["agent", "lifecycle", "hide-reveal", "reload", "realm-isolation"]
}
