{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neko-suite.dev/schemas/nkv-v2.json",
  "title": "NKV Project File",
  "description": "Schema for .nkv video editing project files (v2.0) used by neko-suite",
  "type": "object",
  "required": ["version", "name", "resolution", "fps", "tracks"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0",
      "description": "Project file format version"
    },
    "name": {
      "type": "string",
      "description": "Project name"
    },
    "resolution": {
      "type": "object",
      "description": "Output resolution of the project",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7680,
          "description": "Width in pixels"
        },
        "height": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7680,
          "description": "Height in pixels"
        }
      }
    },
    "fps": {
      "type": "number",
      "minimum": 1,
      "maximum": 240,
      "description": "Frames per second"
    },
    "tracks": {
      "type": "array",
      "description": "Timeline tracks in the project",
      "items": {
        "$ref": "#/$defs/TimelineTrack"
      }
    },
    "defaults": {
      "$ref": "#/$defs/ProjectDefaults",
      "description": "Default values for newly created elements"
    }
  },
  "$defs": {
    "TimelineTrack": {
      "type": "object",
      "description": "A single track in the timeline containing elements",
      "required": ["id", "name", "type", "elements", "muted", "locked", "hidden", "isMain"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique track identifier"
        },
        "name": {
          "type": "string",
          "description": "Display name of the track"
        },
        "type": {
          "type": "string",
          "enum": ["video", "audio", "text", "effect", "subtitle", "shape", "media"],
          "description": "Track type determining what elements it can contain"
        },
        "elements": {
          "type": "array",
          "description": "Elements placed on this track",
          "items": {
            "$ref": "#/$defs/TimelineElement"
          }
        },
        "muted": {
          "type": "boolean",
          "description": "Whether the track is muted"
        },
        "locked": {
          "type": "boolean",
          "description": "Whether the track is locked for editing"
        },
        "hidden": {
          "type": "boolean",
          "description": "Whether the track is hidden from the viewport"
        },
        "isMain": {
          "type": "boolean",
          "description": "Whether this is the main track"
        }
      }
    },
    "TimelineElement": {
      "description": "A timeline element, discriminated by the 'type' field",
      "oneOf": [
        { "$ref": "#/$defs/MediaElement" },
        { "$ref": "#/$defs/AudioElement" },
        { "$ref": "#/$defs/TextElement" },
        { "$ref": "#/$defs/ShapeElement" },
        { "$ref": "#/$defs/SubtitleElement" }
      ]
    },
    "TimelineElementBase": {
      "type": "object",
      "description": "Shared base properties for all timeline elements",
      "required": [
        "id",
        "name",
        "type",
        "duration",
        "startTime",
        "trimStart",
        "trimEnd",
        "transform",
        "opacity",
        "blendMode",
        "effects",
        "muted",
        "hidden",
        "locked"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique element identifier"
        },
        "name": {
          "type": "string",
          "description": "Display name of the element"
        },
        "type": {
          "type": "string",
          "description": "Element type discriminator"
        },
        "duration": {
          "type": "number",
          "minimum": 0,
          "description": "Duration of the element in seconds"
        },
        "startTime": {
          "type": "number",
          "minimum": 0,
          "description": "Start time on the timeline in seconds"
        },
        "trimStart": {
          "type": "number",
          "minimum": 0,
          "description": "Trim offset from the start of the source media in seconds"
        },
        "trimEnd": {
          "type": "number",
          "minimum": 0,
          "description": "Trim offset from the end of the source media in seconds"
        },
        "transform": {
          "$ref": "#/$defs/Transform",
          "description": "Spatial transform of the element"
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Element opacity (0 = fully transparent, 1 = fully opaque)"
        },
        "blendMode": {
          "$ref": "#/$defs/BlendModeType",
          "description": "Blend mode for compositing"
        },
        "effects": {
          "type": "array",
          "description": "Applied effect instances",
          "items": {
            "$ref": "#/$defs/EffectInstance"
          }
        },
        "muted": {
          "type": "boolean",
          "description": "Whether the element is muted"
        },
        "hidden": {
          "type": "boolean",
          "description": "Whether the element is hidden"
        },
        "locked": {
          "type": "boolean",
          "description": "Whether the element is locked"
        },
        "audio": {
          "$ref": "#/$defs/AudioProperties",
          "description": "Audio properties for this element"
        },
        "speed": {
          "$ref": "#/$defs/SpeedProperties",
          "description": "Speed/time-remapping properties"
        },
        "transitionIn": {
          "$ref": "#/$defs/Transition",
          "description": "Incoming transition effect"
        },
        "transitionOut": {
          "$ref": "#/$defs/Transition",
          "description": "Outgoing transition effect"
        }
      }
    },
    "MediaElement": {
      "description": "A media element (video or image)",
      "allOf": [
        { "$ref": "#/$defs/TimelineElementBase" },
        {
          "type": "object",
          "required": ["type", "src"],
          "properties": {
            "type": {
              "const": "media"
            },
            "src": {
              "type": "string",
              "description": "Source file path or URI"
            },
            "resourceId": {
              "type": "string",
              "description": "Reference to a managed resource"
            },
            "mediaType": {
              "type": "string",
              "enum": ["video", "image"],
              "description": "Type of the source media"
            },
            "linkedAudioId": {
              "type": "string",
              "description": "ID of the linked audio element (for video with separated audio)"
            }
          }
        }
      ]
    },
    "AudioElement": {
      "description": "An audio-only element",
      "allOf": [
        { "$ref": "#/$defs/TimelineElementBase" },
        {
          "type": "object",
          "required": ["type", "src"],
          "properties": {
            "type": {
              "const": "audio"
            },
            "src": {
              "type": "string",
              "description": "Source audio file path or URI"
            },
            "resourceId": {
              "type": "string",
              "description": "Reference to a managed resource"
            },
            "linkedVideoId": {
              "type": "string",
              "description": "ID of the linked video element"
            }
          }
        }
      ]
    },
    "TextElement": {
      "description": "A text overlay element",
      "allOf": [
        { "$ref": "#/$defs/TimelineElementBase" },
        {
          "type": "object",
          "required": [
            "type",
            "content",
            "fontSize",
            "fontFamily",
            "color",
            "backgroundColor",
            "textAlign",
            "fontWeight",
            "fontStyle"
          ],
          "properties": {
            "type": {
              "const": "text"
            },
            "content": {
              "type": "string",
              "description": "Text content to display"
            },
            "fontSize": {
              "type": "number",
              "description": "Font size in pixels"
            },
            "fontFamily": {
              "type": "string",
              "description": "Font family name"
            },
            "color": {
              "type": "string",
              "description": "Text color (CSS color value)"
            },
            "backgroundColor": {
              "type": "string",
              "description": "Background color behind text"
            },
            "textAlign": {
              "type": "string",
              "enum": ["left", "center", "right"],
              "description": "Text alignment"
            },
            "fontWeight": {
              "type": "string",
              "enum": ["normal", "bold"],
              "description": "Font weight"
            },
            "fontStyle": {
              "type": "string",
              "enum": ["normal", "italic"],
              "description": "Font style"
            },
            "textDecoration": {
              "type": "string",
              "enum": ["none", "underline", "line-through"],
              "description": "Text decoration style"
            },
            "lineHeight": {
              "type": "number",
              "description": "Line height multiplier"
            },
            "letterSpacing": {
              "type": "number",
              "description": "Letter spacing in pixels"
            },
            "strokeColor": {
              "type": "string",
              "description": "Text stroke color"
            },
            "strokeWidth": {
              "type": "number",
              "description": "Text stroke width in pixels"
            },
            "shadow": {
              "$ref": "#/$defs/TextShadow",
              "description": "Text shadow properties"
            }
          }
        }
      ]
    },
    "ShapeElement": {
      "description": "A vector shape element",
      "allOf": [
        { "$ref": "#/$defs/TimelineElementBase" },
        {
          "type": "object",
          "required": ["type", "shapeType", "fill", "stroke", "strokeWidth"],
          "properties": {
            "type": {
              "const": "shape"
            },
            "shapeType": {
              "type": "string",
              "description": "Type of shape (e.g. rectangle, ellipse, polygon)"
            },
            "fill": {
              "type": "string",
              "description": "Fill color (CSS color value)"
            },
            "stroke": {
              "type": "string",
              "description": "Stroke color (CSS color value)"
            },
            "strokeWidth": {
              "type": "number",
              "description": "Stroke width in pixels"
            }
          }
        }
      ]
    },
    "SubtitleElement": {
      "description": "A subtitle overlay element",
      "allOf": [
        { "$ref": "#/$defs/TimelineElementBase" },
        {
          "type": "object",
          "required": [
            "type",
            "text",
            "fontSize",
            "color",
            "fontFamily",
            "backgroundColor",
            "textAlign",
            "strokeColor",
            "strokeWidth"
          ],
          "properties": {
            "type": {
              "const": "subtitle"
            },
            "text": {
              "type": "string",
              "description": "Subtitle text content"
            },
            "fontSize": {
              "type": "number",
              "description": "Font size in pixels"
            },
            "color": {
              "type": "string",
              "description": "Text color (CSS color value)"
            },
            "fontFamily": {
              "type": "string",
              "description": "Font family name"
            },
            "backgroundColor": {
              "type": "string",
              "description": "Background color behind subtitle"
            },
            "textAlign": {
              "type": "string",
              "description": "Text alignment"
            },
            "strokeColor": {
              "type": "string",
              "description": "Text stroke color"
            },
            "strokeWidth": {
              "type": "number",
              "description": "Text stroke width in pixels"
            },
            "shadow": {
              "$ref": "#/$defs/TextShadow",
              "description": "Subtitle shadow properties"
            }
          }
        }
      ]
    },
    "Transform": {
      "type": "object",
      "description": "2D spatial transform",
      "required": ["x", "y", "scaleX", "scaleY", "rotation", "anchorX", "anchorY"],
      "properties": {
        "x": {
          "type": "number",
          "description": "X position in pixels"
        },
        "y": {
          "type": "number",
          "description": "Y position in pixels"
        },
        "scaleX": {
          "type": "number",
          "description": "Horizontal scale factor"
        },
        "scaleY": {
          "type": "number",
          "description": "Vertical scale factor"
        },
        "rotation": {
          "type": "number",
          "description": "Rotation in degrees"
        },
        "anchorX": {
          "type": "number",
          "description": "Anchor point X (0-1, relative to element width)"
        },
        "anchorY": {
          "type": "number",
          "description": "Anchor point Y (0-1, relative to element height)"
        }
      }
    },
    "AudioProperties": {
      "type": "object",
      "description": "Audio mixing and processing properties",
      "required": ["volume", "pan", "muted", "fadeIn", "fadeOut"],
      "properties": {
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Volume level (0 = silent, 1 = full)"
        },
        "pan": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Stereo panning (-1 = left, 0 = center, 1 = right)"
        },
        "muted": {
          "type": "boolean",
          "description": "Whether audio is muted"
        },
        "fadeIn": {
          "type": "number",
          "minimum": 0,
          "description": "Fade-in duration in seconds"
        },
        "fadeOut": {
          "type": "number",
          "minimum": 0,
          "description": "Fade-out duration in seconds"
        },
        "fadeInCurve": {
          "$ref": "#/$defs/EasingType",
          "description": "Easing curve for fade-in"
        },
        "fadeOutCurve": {
          "$ref": "#/$defs/EasingType",
          "description": "Easing curve for fade-out"
        },
        "gain": {
          "type": "number",
          "description": "Additional gain in dB"
        },
        "eq": {
          "type": "object",
          "description": "3-band equalizer",
          "required": ["lowGain", "midGain", "highGain"],
          "properties": {
            "lowGain": {
              "type": "number",
              "description": "Low frequency gain in dB"
            },
            "midGain": {
              "type": "number",
              "description": "Mid frequency gain in dB"
            },
            "highGain": {
              "type": "number",
              "description": "High frequency gain in dB"
            }
          }
        }
      }
    },
    "SpeedProperties": {
      "type": "object",
      "description": "Playback speed and time remapping",
      "required": ["speed", "preservePitch", "reverse"],
      "properties": {
        "speed": {
          "type": "number",
          "description": "Playback speed multiplier (1.0 = normal)"
        },
        "preservePitch": {
          "type": "boolean",
          "description": "Whether to preserve pitch when changing speed"
        },
        "reverse": {
          "type": "boolean",
          "description": "Whether to play in reverse"
        },
        "timeRemap": {
          "type": "object",
          "description": "Keyframe-based time remapping",
          "required": ["enabled", "keyframes"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Whether time remapping is active"
            },
            "keyframes": {
              "type": "array",
              "description": "Time remap keyframes",
              "items": {
                "type": "object",
                "required": ["id", "outputTime", "inputTime", "easing"],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Unique keyframe identifier"
                  },
                  "outputTime": {
                    "type": "number",
                    "description": "Time on the timeline (output)"
                  },
                  "inputTime": {
                    "type": "number",
                    "description": "Time in the source media (input)"
                  },
                  "easing": {
                    "$ref": "#/$defs/EasingType",
                    "description": "Interpolation easing to the next keyframe"
                  }
                }
              }
            }
          }
        }
      }
    },
    "EffectInstance": {
      "type": "object",
      "description": "An applied effect instance with parameters",
      "required": ["id", "type", "enabled", "parameters", "order"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique effect instance identifier"
        },
        "type": {
          "type": "string",
          "description": "Effect type identifier"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether the effect is enabled"
        },
        "parameters": {
          "type": "object",
          "description": "Effect parameter values",
          "additionalProperties": {
            "oneOf": [
              { "type": "number" },
              { "type": "boolean" },
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2
              }
            ]
          }
        },
        "animatedParameters": {
          "type": "object",
          "description": "Parameters with keyframe animation",
          "additionalProperties": {
            "type": "object",
            "required": ["baseValue", "keyframes"],
            "properties": {
              "baseValue": {
                "oneOf": [
                  { "type": "number" },
                  { "type": "boolean" },
                  { "type": "string" },
                  {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 2,
                    "maxItems": 2
                  }
                ],
                "description": "Base value when no keyframes are active"
              },
              "keyframes": {
                "type": "array",
                "description": "Animation keyframes",
                "items": {
                  "type": "object",
                  "required": ["id", "time", "value", "easing"],
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Unique keyframe identifier"
                    },
                    "time": {
                      "type": "number",
                      "description": "Keyframe time in seconds"
                    },
                    "value": {
                      "oneOf": [
                        { "type": "number" },
                        { "type": "boolean" },
                        { "type": "string" },
                        {
                          "type": "array",
                          "items": { "type": "number" },
                          "minItems": 2,
                          "maxItems": 2
                        }
                      ],
                      "description": "Keyframe value"
                    },
                    "easing": {
                      "$ref": "#/$defs/EasingType",
                      "description": "Easing to the next keyframe"
                    }
                  }
                }
              }
            }
          }
        },
        "order": {
          "type": "number",
          "description": "Effect processing order (lower = earlier)"
        }
      }
    },
    "Transition": {
      "type": "object",
      "description": "A transition effect between elements",
      "required": ["type", "duration", "easing"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique transition identifier"
        },
        "type": {
          "$ref": "#/$defs/TransitionType",
          "description": "Transition effect type"
        },
        "duration": {
          "type": "number",
          "description": "Transition duration in seconds"
        },
        "easing": {
          "$ref": "#/$defs/EasingType",
          "description": "Transition easing curve"
        },
        "params": {
          "type": "object",
          "description": "Additional transition parameters",
          "properties": {
            "direction": {
              "type": "string",
              "description": "Direction of the transition"
            },
            "softness": {
              "type": "number",
              "description": "Edge softness of the transition"
            },
            "color": {
              "type": "string",
              "description": "Color used by the transition (CSS color value)"
            }
          }
        }
      }
    },
    "TextShadow": {
      "type": "object",
      "description": "Text shadow properties",
      "required": ["color", "offsetX", "offsetY", "blur"],
      "properties": {
        "color": {
          "type": "string",
          "description": "Shadow color (CSS color value)"
        },
        "offsetX": {
          "type": "number",
          "description": "Horizontal shadow offset in pixels"
        },
        "offsetY": {
          "type": "number",
          "description": "Vertical shadow offset in pixels"
        },
        "blur": {
          "type": "number",
          "description": "Shadow blur radius in pixels"
        }
      }
    },
    "BlendModeType": {
      "type": "string",
      "description": "Photoshop-compatible blend mode",
      "enum": [
        "normal",
        "dissolve",
        "darken",
        "multiply",
        "colorBurn",
        "linearBurn",
        "darkerColor",
        "lighten",
        "screen",
        "colorDodge",
        "linearDodge",
        "lighterColor",
        "overlay",
        "softLight",
        "hardLight",
        "vividLight",
        "linearLight",
        "pinLight",
        "hardMix",
        "difference",
        "exclusion",
        "subtract",
        "divide",
        "hue",
        "saturation",
        "color",
        "luminosity"
      ]
    },
    "EasingType": {
      "type": "string",
      "description": "Animation easing function",
      "enum": [
        "linear",
        "ease-in-quad",
        "ease-out-quad",
        "ease-in-out-quad",
        "ease-in-cubic",
        "ease-out-cubic",
        "ease-in-out-cubic",
        "ease-in-quart",
        "ease-out-quart",
        "ease-in-out-quart",
        "ease-in-quint",
        "ease-out-quint",
        "ease-in-out-quint",
        "ease-in-sine",
        "ease-out-sine",
        "ease-in-out-sine",
        "ease-in-expo",
        "ease-out-expo",
        "ease-in-out-expo",
        "ease-in-circ",
        "ease-out-circ",
        "ease-in-out-circ",
        "ease-in-back",
        "ease-out-back",
        "ease-in-out-back",
        "ease-in-elastic",
        "ease-out-elastic",
        "ease-in-out-elastic",
        "ease-in-bounce",
        "ease-out-bounce",
        "ease-in-out-bounce",
        "cubic-bezier"
      ]
    },
    "TransitionType": {
      "type": "string",
      "description": "Available transition effects",
      "enum": [
        "fade",
        "dissolve",
        "wipe-left",
        "wipe-right",
        "wipe-up",
        "wipe-down",
        "slide-left",
        "slide-right",
        "zoom-in",
        "zoom-out",
        "iris-circle",
        "iris-rectangle",
        "clock",
        "pixelate",
        "ripple",
        "swirl",
        "glitch",
        "flash"
      ]
    },
    "ProjectDefaults": {
      "type": "object",
      "description": "Default values applied to newly created elements",
      "properties": {
        "text": {
          "type": "object",
          "description": "Default text element properties",
          "properties": {
            "fontSize": { "type": "number" },
            "fontFamily": { "type": "string" },
            "color": { "type": "string" },
            "backgroundColor": { "type": "string" },
            "textAlign": { "type": "string", "enum": ["left", "center", "right"] },
            "fontWeight": { "type": "string", "enum": ["normal", "bold"] },
            "fontStyle": { "type": "string", "enum": ["normal", "italic"] },
            "textDecoration": { "type": "string", "enum": ["none", "underline", "line-through"] }
          }
        },
        "transform": {
          "type": "object",
          "description": "Default transform properties",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "scaleX": { "type": "number" },
            "scaleY": { "type": "number" },
            "rotation": { "type": "number" },
            "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "audio": {
          "type": "object",
          "description": "Default audio properties",
          "properties": {
            "volume": { "type": "number", "minimum": 0, "maximum": 1 },
            "pan": { "type": "number", "minimum": -1, "maximum": 1 },
            "fadeIn": { "type": "number", "minimum": 0 },
            "fadeOut": { "type": "number", "minimum": 0 },
            "gain": { "type": "number" }
          }
        }
      }
    }
  }
}
