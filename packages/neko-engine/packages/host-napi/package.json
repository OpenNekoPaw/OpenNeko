{
  "name": "@neko-engine/host-napi",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js N-API bindings for neko-engine-kernel",
  "main": "loader.js",
  "types": "index.d.ts",
  "napi": {
    "name": "neko-engine",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build:native": "pnpm run build:napi",
    "build:napi": "node ../../scripts/build-napi.js --release",
    "build:debug": "node ../../scripts/build-napi.js",
    "artifacts": "pnpm exec @napi-rs/cli artifacts",
    "prepublishOnly": "pnpm exec @napi-rs/cli prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "engines": {
    "node": ">= 24"
  },
  "files": [
    "loader.js",
    "native-binding-loader.js",
    "index.d.ts",
    "*.node"
  ],
  "license": "AGPL-3.0-or-later"
}
