{
  "name": "@neko-engine/host-napi",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js N-API bindings for neko-engine-kernel",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "neko-engine",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build:native": "pnpm run build:napi",
    "build:napi": "node ../../scripts/run-with-ffmpeg-env.js -- pnpm exec napi build --platform --release",
    "build:debug": "node ../../scripts/run-with-ffmpeg-env.js -- pnpm exec napi build --platform",
    "artifacts": "pnpm exec @napi-rs/cli artifacts",
    "prepublishOnly": "pnpm exec @napi-rs/cli prepublish -t npm",
    "universal": "pnpm exec @napi-rs/cli universal"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "engines": {
    "node": ">= 24"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "license": "AGPL-3.0-or-later"
}
