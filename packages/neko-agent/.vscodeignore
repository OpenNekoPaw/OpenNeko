# Source code (not needed in VSIX — dist/ has compiled output)
src/**

# Sub-packages — exclude all, then re-include webview dist
packages/**
!packages/webview/dist/**

# Config & tooling
.vscode/**
.vscode-test/**
.turbo/**
.claude/**
.serena/**
.gitignore
tsconfig.json
tsconfig.*.json
eslint.config.*
vitest.config.*
vite.config.*
postcss.config.*
tailwind.config.*
*.md

# TypeScript source (redundant with src/** but catches root-level .ts)
*.ts
!*.d.ts

# Test & coverage artifacts
**/*.test.ts
**/*.spec.ts
**/__tests__/**
coverage/**

# Build intermediaries
node_modules/**
out/**
*.map
*.tsbuildinfo

# CLI binary (built separately, not part of extension)
neko

# Test utilities
test-utils/**

# Build and packaging scripts (run before VSIX file collection)
scripts/**

# Docs (not needed in VSIX)
docs/**

# Include compiled output and localization
!dist/**
!l10n/**
