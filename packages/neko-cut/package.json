{
  "name": "neko-cut",
  "displayName": "NekoCut",
  "description": "Lightweight media editing for VS Code",
  "version": "0.0.1",
  "publisher": "neko",
  "l10n": "./l10n",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/neko/creative-suite"
  },
  "engines": {
    "vscode": "^1.128.0"
  },
  "categories": ["Other", "Visualization"],
  "keywords": ["video", "editor", "timeline", "editing"],
  "extensionKind": ["workspace"],
  "extensionDependencies": ["neko.neko-engine", "neko.neko-tools", "neko.neko-preview"],
  "activationEvents": [
    "onInstallType:shader",
    "onCustomEditor:neko.cut.otioEditor",
    "onCommand:neko.cut.newProject"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "neko.installTargets": [
      {
        "type": "shader",
        "activationEvent": "onInstallType:shader"
      }
    ],
    "commands": [
      {
        "command": "neko.cut.newProject",
        "title": "%neko.cut.newProject.title%",
        "category": "NekoCut"
      },
      {
        "command": "neko.cut.previewMedia",
        "title": "%neko.cut.previewMedia.title%",
        "category": "NekoCut"
      }
    ],
    "customEditors": [
      {
        "viewType": "neko.cut.otioEditor",
        "displayName": "Neko Cut",
        "selector": [{ "filenamePattern": "*.otio" }],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "NekoCut",
      "properties": {
        "neko.cut.defaultProjectRoot": {
          "type": "string",
          "default": "projects/cut",
          "description": "Workspace-relative directory used only for new .otio documents."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "pnpm run compile:extension && pnpm run compile:webview && pnpm run copy:webview",
    "compile:extension": "esbuild ./packages/extension/src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "compile:webview": "cd packages/webview && pnpm run build",
    "copy:webview": "rm -rf dist/webview && mkdir -p dist/webview/assets && cp packages/webview/dist/*.html dist/webview/ && cp -R packages/webview/dist/assets/* dist/webview/assets/",
    "watch": "pnpm run compile:extension -- --watch",
    "lint": "eslint packages/extension/src --ext ts,tsx",
    "test": "vitest",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.125.0",
    "esbuild": "^0.19.8",
    "typescript": "^5.3.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {}
}
