# Source code (not needed in VSIX — dist/ has compiled output)
src/**
packages/**

# Config & tooling
.vscode/**
.vscode-test/**
.turbo/**
.claude/**
.serena/**
.gitignore
tsconfig.json
tsconfig.*.json
eslint.config.*
vitest.config.*
vite.config.*
postcss.config.*
tailwind.config.*
*.md

# TypeScript source (redundant with src/** but catches root-level .ts)
*.ts
!*.d.ts

# Test & coverage artifacts
**/*.test.ts
**/*.spec.ts
**/__tests__/**
coverage/**

# Build intermediaries
node_modules/**
out/**
*.map
*.tsbuildinfo

# Include compiled output and localization
!dist/**
!l10n/**
