{
  "name": "openneko-monorepo",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.29.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/*/packages/*",
    "packages/*/test-utils"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:ui": "turbo run build --filter=@neko/webview --filter=@neko-tools/webview --filter=@neko/preview-webview --filter=@neko-agent/webview --filter=@neko-canvas/webview",
    "build:release": "pnpm compile:ts-vsix",
    "build:dev": "turbo run compile --filter='neko-*'",
    "build:neko-engine": "turbo run compile --filter=neko-engine",
    "build:neko-preview": "turbo run compile --filter=neko-preview",
    "build:neko-cut": "turbo run compile --filter=neko-cut",
    "build:neko-agent": "turbo run compile --filter=neko-agent",
    "compile:ts-vsix": "node scripts/compile-ts-vsix.mjs",
    "dev": "turbo run dev --filter=neko-cut",
    "dev:neko": "turbo run watch --filter=neko-cut",
    "lint": "eslint \"packages/**/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"packages/**/src/**/*.{ts,tsx}\" --fix",
    "lint:turbo": "turbo run lint",
    "test": "turbo run test --concurrency=2",
    "test:coverage": "turbo run test --concurrency=2 --continue=always -- --run --coverage",
    "test:agent:mock": "pnpm --filter neko-agent run test:agent:mock",
    "test:agent:eval": "vitest --config vitest.agent-eval.config.mts --run && node scripts/agent-eval/all-suite-dry-run.mjs",
    "package:all": "turbo run package --filter='neko-*'",
    "package:vscode": "pnpm --dir apps/neko-vscode run package",
    "clean": "turbo run clean && rm -rf .turbo node_modules/.cache",
    "generate:types": "node scripts/proto-gen-ts.mjs",
    "generate:webview:functional:preview-fixtures": "node scripts/webview-functional/fixtures/preview-documents/generate.mjs",
    "nekoagent": "pnpm --filter @neko/app-tui dev",
    "format": "prettier --write \"packages/**/src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"packages/**/src/**/*.{ts,tsx,json}\"",
    "check:unused": "knip",
    "check:unused:fix": "knip --fix",
    "check:legacy-debt": "node scripts/check-legacy-debt-surfaces.mjs",
    "check:legacy-debt:ledger": "node scripts/check-legacy-debt-surfaces.mjs --validate-ledger",
    "check:content-access-boundaries": "node scripts/check-content-access-boundaries.mjs",
    "check:application-boundaries": "node scripts/check-application-boundaries.mjs --self-test && node scripts/check-application-boundaries.mjs",
    "check:product-brand": "node scripts/check-product-brand.mjs",
    "check:agent-boundaries": "node scripts/check-neko-agent-boundaries.mjs",
    "check:canvas-playback-boundary": "node scripts/check-canvas-playback-boundary.mjs",
    "check:release-channels": "node scripts/check-release-channels.mjs",
    "check:openspec": "node scripts/check-openspec.mjs",
    "check:strict-tsconfig": "node scripts/check-strict-tsconfig.mjs",
    "check:local-metadata-runtimes": "node scripts/check-local-metadata-runtime-matrix.mjs",
    "check:strict-extensions": "pnpm exec tsc --noEmit -p packages/neko-agent/packages/extension/tsconfig.json && pnpm exec tsc --noEmit -p packages/neko-engine/packages/extension/tsconfig.json",
    "check:test-orchestration": "node --test scripts/test-orchestration/*.test.mjs scripts/webview-functional/*.test.mjs && node scripts/test-orchestration/audit-test-ownership.mjs && node scripts/test-orchestration/audit-coverage-config.mjs && node scripts/webview-functional/cli.mjs --dry-run",
    "check:webview-boundaries": "node scripts/check-webview-boundaries.mjs",
    "check:quality": "pnpm check:release-channels && pnpm check:product-brand && pnpm check:legacy-debt:ledger && pnpm check:content-access-boundaries && pnpm check:application-boundaries && pnpm check:agent-boundaries && pnpm check:canvas-playback-boundary && pnpm check:webview-boundaries && pnpm check:strict-tsconfig && pnpm check:strict-extensions && pnpm check:local-metadata-runtimes && pnpm check:test-orchestration && pnpm check:openspec",
    "check:deps": "depcruise packages/neko-types/src packages/neko-host/src packages/neko-client/src packages/neko-engine/packages/extension/src packages/neko-cut/packages/extension/src packages/neko-cut/packages/webview/src packages/neko-agent/packages/extension/src packages/neko-agent/packages/platform/src packages/neko-agent/packages/agent/src packages/neko-canvas/packages/webview/src packages/neko-preview/packages/extension/src --config",
    "check": "pnpm check:unused && pnpm check:deps",
    "check:build": "pnpm format:check && pnpm lint && pnpm build",
    "check:test": "pnpm test:coverage",
    "check:repository-quality": "pnpm check && pnpm check:quality",
    "check:ci": "pnpm check:build && pnpm check:test && pnpm check:repository-quality",
    "check:fast": "pnpm lint && pnpm test -- --run",
    "ci:local": "pnpm check:ci",
    "ci:local:proto": "pnpm generate:types && git diff --exit-code packages/neko-types/src/generated/",
    "ci:act": "scripts/act-ci.sh",
    "ci:act:list": "scripts/act-ci.sh --list",
    "smoke:engine": "pnpm --filter neko-engine test",
    "smoke:webview": "node scripts/smoke-webview-builds.mjs",
    "smoke:vscode:targets": "node scripts/smoke-vscode-targets.mjs",
    "smoke:webview:targets": "node scripts/smoke-vscode-targets.mjs --skill vscode-extension-debugger --require-webview",
    "test:webview:functional": "node scripts/webview-functional/cli.mjs",
    "test:webview:functional:dry-run": "node scripts/webview-functional/cli.mjs --dry-run",
    "test:webview:functional:p0": "node scripts/webview-functional/cli.mjs --tier p0",
    "smoke": "pnpm smoke:engine && pnpm smoke:webview",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/**/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/src/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@img/sharp-wasm32": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@earendil-works/pi-agent-core": "^0.80.7",
    "@fission-ai/openspec": "1.3.1",
    "@neko/shared": "workspace:*",
    "@vitest/coverage-v8": "4.1.2",
    "@vscode/vsce": "^3.9.2",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.1",
    "protobufjs": "^8.6.5",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "6.4.2",
    "vitest": "4.1.2",
    "ws": "8.18.3",
    "yaml": "2.9.0"
  }
}
